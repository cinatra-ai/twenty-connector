{
  "name": "@cinatra-ai/twenty-connector",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "files": [
    "src",
    "!src/__tests__"
  ],
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./register": "./src/register.ts",
    "./deps": "./src/deps.ts",
    "./mcp-module": "./src/mcp/module.ts",
    "./setup-page": "./src/setup-page.tsx"
  },
  "types": "./src/index.ts",
  "scripts": {
    "test": "vitest run",
    "lint": "eslint . --no-inline-config"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "server-only": "0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@cinatra-ai/sdk-extensions": "*",
    "@cinatra-ai/sdk-ui": "*"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-extensions": {
      "optional": true
    },
    "@cinatra-ai/sdk-ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/parser": "8.61.0",
    "eslint": "10.4.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.6"
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "connector",
    "displayName": "Twenty CRM",
    "dependencies": [
      {
        "packageName": "@cinatra-ai/crm-connector",
        "kind": "connector",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "exact",
          "version": "0.1.1"
        },
        "requirement": "required"
      }
    ],
    "serverEntry": "./register",
    "requestedHostPorts": [
      "capabilities"
    ],
    "sdkAbiRange": "^2"
  }
}
